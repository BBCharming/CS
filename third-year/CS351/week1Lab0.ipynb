   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from decimal import Decimal, getcontext\n",
    "\n",
    "# 1. Setup points for N (Logarithmic scale from 10^1 to 10^6)\n",
    "N_vals = np.logspace(1, 6, 20).astype(int)\n",
    "errors_32 = []\n",
    "errors_64 = []\n",
    "\n",
    "# Setup High Precision\n",
    "getcontext().prec = 50\n",
    "exact_sum = Decimal(0)\n",
    "last_n = 1\n",
    "\n",
    "print(\"Calculating errors for plot (this may take a few seconds)...\")\n",
    "\n",
    "# 2. Loop through N values and calculate errors\n",
    "for n in N_vals:\n",
    "    # Update exact sum cumulatively for speed\n",
    "    for k in range(last_n, n + 1):\n",
    "        exact_sum += Decimal(1) / Decimal(k)\n",
    "    last_n = n + 1\n",
    "    ref = float(exact_sum)\n",
    "    \n",
    "    # Calculate float32 and float64 sums\n",
    "    # We use numpy.arange for speed\n",
    "    k_arr = np.arange(1, n + 1)\n",
    "    s32 = np.sum(k_arr.astype(np.float32)**-1)\n",
    "    s64 = np.sum(k_arr.astype(np.float64)**-1)\n",
    "    \n",
    "    # Store relative errors\n",
    "    errors_32.append(abs(s32 - ref) / ref)\n",
    "    errors_64.append(abs(s64 - ref) / ref)\n",
    "\n",
    "# 3. Generate the Visual\n",
    "plt.figure(figsize=(11, 6))\n",
    "\n",
    "# Use loglog to match the \"log scale\" requirement in your slide\n",
    "plt.loglog(N_vals, errors_32, color='#A52A2A', lw=3, label='float32') # Red/Brown\n",
    "plt.loglog(N_vals, errors_64, color='#4682B4', lw=3, label='float64') # Steel Blue\n",
    "\n",
    "# Match the labels from the slide\n",
    "plt.text(N_vals[-1], errors_32[-1], '  float32', color='#A52A2A', fontweight='bold', va='center')\n",
    "plt.text(N_vals[-1], errors_64[-1], '  float64', color='#4682B4', fontweight='bold', va='center')\n",
    "\n",
    "# Formatting\n",
    "plt.xlabel('N (number of terms, log scale)', fontsize=12)\n",
    "plt.ylabel('Relative Error (log scale)', fontsize=12)\n",
    "plt.title('Task 1 Visual: Expected Error Convergence', fontsize=14, fontweight='bold')\n",
    "plt.grid(True, which=\"both\", ls=\"-\", alpha=0.2)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
