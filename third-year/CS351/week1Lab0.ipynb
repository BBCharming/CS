    "#Task 4: Kahan Compensated Summation \n",
    "def kahan_sum(arr):\n",
    "    \"\"\"Kahan compensated summation.\n",
    "    c tracks the running compensation for low-order bits lost each addition.\n",
    "    \"\"\"\n",
    "    total = type(arr[0])(0.0) \n",
    "    c = type(arr[0])(0.0)  # compensation \n",
    "    for x in arr:\n",
    "        y = x - c          # corrected addend \n",
    "        t = total + y      # new total\n",
    "        c = (t - total) - y  # bits lost \n",
    "        total = t\n",
    "    return total \n",
    "# Compare accuracy: naive, Kahan, float64 ref"
   ]
